# =========================
# 基础配置
# =========================
SECRET_KEY=stock-analysis-secret-key-2024
SQLITE_DB_PATH=

# =========================
# Tavily 全网搜索
# =========================
TAVILY_API_KEY=tvly-your-api-key
TAVILY_BASE_URL=https://api.tavily.com/search
TAVILY_SEARCH_DEPTH=basic
TAVILY_MAX_RESULTS=5
TAVILY_TIMEOUT_SECONDS=20
TAVILY_TIME_RANGE=
TAVILY_INCLUDE_ANSWER=true
TAVILY_INCLUDE_RAW_CONTENT=false
TAVILY_INCLUDE_IMAGES=false
TAVILY_INCLUDE_IMAGE_DESCRIPTIONS=false
TAVILY_INCLUDE_FAVICON=false
TAVILY_AUTO_PARAMETERS=false
TAVILY_COUNTRY=
TAVILY_CHUNKS_PER_SOURCE=3
TAVILY_CACHE_EXPIRE=1800
TAVILY_INCLUDE_DOMAINS=
TAVILY_EXCLUDE_DOMAINS=
ENABLE_WEB_SEARCH_CONTEXT=true

# =========================
# 钉钉机器人通知
# =========================
DINGTALK_ENABLED=false
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxxx
DINGTALK_SECRET=
DINGTALK_AT_MOBILES=
DINGTALK_NOTIFY_ON_DEBATE=false

# =========================
# 钉钉应用机器人（Stream 模式）
# 你当前有的 AppKey/AppSecret/AgentId 对应这块
# =========================
DINGTALK_STREAM_ENABLED=true
DINGTALK_CLIENT_ID=dingxxxxxxxx
DINGTALK_CLIENT_SECRET=xxxxxxxx
DINGTALK_AGENT_ID=123456789

# =========================
# AI 模型默认配置
# 说明：
# 1. AI_DEFAULT_* 是全局默认值
# 2. AI_BULL/BEAR/JUDGE_* 会覆盖对应角色
# 3. 前端设置面板里填写的值会覆盖 .env 默认值
# =========================
AI_REQUEST_TIMEOUT_SECONDS=120
AI_DEFAULT_API_KEY=
AI_DEFAULT_BASE_URL=
AI_DEFAULT_MODEL=

AI_BULL_API_KEY=
AI_BULL_BASE_URL=
AI_BULL_MODEL=

AI_BEAR_API_KEY=
AI_BEAR_BASE_URL=
AI_BEAR_MODEL=

AI_JUDGE_API_KEY=
AI_JUDGE_BASE_URL=
AI_JUDGE_MODEL=
